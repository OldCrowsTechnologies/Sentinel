{
  "name": "corvus-sentinel",
  "version": "1.0.0",
  "description": "Persistent air-defense monitor - acoustic drone detection for OCWS",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "parity": "bash training/run_parity.sh",
    "train": "python3 training/train_corvus.py",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "capture": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types tools/rf_field.mjs",
    "ingest": "node tools/audio_ingest.mjs",
    "scan": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types tools/rf_scan.mjs",
    "console": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types tools/rf_console.mjs",
    "stress": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types stress/index.mjs",
    "stress:soak": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --expose-gc --experimental-strip-types stress/index.mjs soak"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/rajdhani": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@supabase/supabase-js": "^2.110.1",
    "expo": "^55.0.27",
    "expo-dev-client": "~55.0.36",
    "expo-file-system": "~55.0.23",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.15",
    "expo-linear-gradient": "~55.0.15",
    "expo-location": "~55.1.11",
    "expo-network": "~55.0.15",
    "expo-notifications": "~55.0.24",
    "expo-sharing": "~55.0.21",
    "expo-sqlite": "~55.0.17",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-audio-api": "^0.8.0",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-tcp-socket": "^6.4.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
