node_modules/
.expo/
dist/
web-build/
*.log
.env
ios/
android/
training/parity_cases.json
training/__pycache__/
*.pyc
.DS_Store
.claude/

# Training audio is versioned via Git LFS (see .gitattributes) -- keeps the WAVs
# in the repo without bloating clones or EAS build uploads (builds get pointers,
# and .easignore drops data/ from the archive anyway).
# RF capture corpus: raw IQ is large + binary. Keep the .iq8 out of git, but
# version the self-describing .json sidecars + README so the corpus is documented.
captures/**/*.iq8

# Third-party datasets (C3GD, FSD50K, ...). Re-downloadable from the pinned
# Zenodo record ids in NOTICE, so we don't version them -- provenance lives in
# NOTICE, not in the object store. First-party captures DO get versioned (above).
data/external/

# Windows rtl-sdr binaries (rtl_tcp.exe + DLLs) — vendored locally for field
# capture convenience; not source, don't bloat the repo.
tools/rtlsdr-win/

# Model/branding backups
*.BACKUP*.json
assets/branding/*_original_backup*

# Sensor node runtime config holds a seat code + session token.
sensor-node/node.json
sensor-node/.session.json
