# Corvus Sentinel environment
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to app code.

# ElevenLabs API key for Corvus voice briefs (optional).
# Without it, briefs degrade to console log + haptics.
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Locked Corvus voice ID (do not change)
# Oq6YjhFgak69fZQyDSCd

# Shared specimen library endpoint (POST target for auto-uploaded unknown-build
# captures). Leave blank to keep specimens on-device only until the backend
# exists. Expected to accept a JSON specimen body.
EXPO_PUBLIC_CORVUS_LIBRARY_URL=
